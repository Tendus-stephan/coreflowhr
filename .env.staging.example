# ============================================================
# STAGING ENVIRONMENT — set these in Vercel staging project
# Dashboard → Project → Settings → Environment Variables
# Environment: Production (the staging project's production env)
# ============================================================
# NEVER use prod Supabase values here.
# NEVER use Stripe live keys here — always use test keys.

# ── Supabase (staging project) ──────────────────────────────
# Create a new project at https://supabase.com/dashboard
# Then run: bash scripts/setup-staging-db.sh <staging-project-ref>
VITE_SUPABASE_URL=https://<STAGING_PROJECT_REF>.supabase.co
VITE_SUPABASE_ANON_KEY=<STAGING_ANON_KEY>

# ── Stripe (always use TEST keys on staging) ─────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_<STAGING_STRIPE_TEST_KEY>
VITE_STRIPE_PRICE_ID_PROFESSIONAL_MONTHLY=price_<STAGING_TEST_PRICE_ID>
VITE_STRIPE_PRICE_ID_FOUNDING_MONTHLY=price_<STAGING_TEST_PRICE_ID>

# ── Frontend URL ─────────────────────────────────────────────
VITE_FRONTEND_URL=https://staging.coreflowhr.com

# ── Sentry (use a separate staging DSN or leave blank) ───────
VITE_SENTRY_DSN=

# ── Calendly ─────────────────────────────────────────────────
VITE_CALENDLY_URL=https://calendly.com/coreflowhr/product-demo

# ============================================================
# Edge Function secrets — set these with the Supabase CLI:
#
#   npx supabase secrets set KEY=value --project-ref <STAGING_REF>
#
# Or bulk-set from a file:
#   npx supabase secrets set --env-file .env.staging.secrets --project-ref <STAGING_REF>
# ============================================================

# ── Email (Resend) ───────────────────────────────────────────
# Use a staging/test Resend API key or subdomain (staging-mail.coreflowhr.com)
RESEND_API_KEY=re_<STAGING_RESEND_KEY>

# Staging FROM_NAME includes "Staging" so test emails are clearly identifiable.
# No code change needed — this env var is read by send-email/index.ts.
FROM_EMAIL=staging@coreflowhr.com
FROM_NAME=CoreflowHR Staging
REPLY_TO_EMAIL=staging@coreflowhr.com

# Force ALL outbound emails to this address on staging (safety net).
# Set to your own email while testing; remove or leave blank for production-like testing.
RESEND_FORCE_TO=

# Resend webhook secret — from Resend dashboard → Webhooks → staging endpoint.
# Add webhook URL: https://<STAGING_REF>.supabase.co/functions/v1/receive-candidate-email
RESEND_WEBHOOK_SECRET=<STAGING_RESEND_WEBHOOK_SECRET>

# ── Stripe ───────────────────────────────────────────────────
# NEVER use sk_live_ on staging. Always sk_test_.
STRIPE_SECRET_KEY=sk_test_<STAGING_STRIPE_TEST_SECRET>

# Create a separate webhook endpoint in Stripe dashboard → Test mode → Webhooks
# pointing to: https://<STAGING_REF>.supabase.co/functions/v1/stripe-webhook
STRIPE_WEBHOOK_SECRET=whsec_<STAGING_STRIPE_TEST_WEBHOOK_SECRET>

# ── Google OAuth ─────────────────────────────────────────────
# In Google Cloud Console → APIs & Services → Credentials:
#   1. Edit your OAuth 2.0 client
#   2. Add https://staging.coreflowhr.com/auth/callback to Authorized redirect URIs
#   3. Add https://<STAGING_REF>.supabase.co/functions/v1/connect-google-callback
# You can reuse prod client ID/secret if redirect URIs are configured above.
GOOGLE_CLIENT_ID=<GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<GOOGLE_CLIENT_SECRET>

# ── Microsoft / Teams ─────────────────────────────────────────
# In Azure portal → App registrations → your app → Authentication:
#   Add https://<STAGING_REF>.supabase.co/functions/v1/connect-teams-callback
#   as a redirect URI. Can reuse the same Azure app as prod.
MICROSOFT_CLIENT_ID=<MICROSOFT_CLIENT_ID>
MICROSOFT_CLIENT_SECRET=<MICROSOFT_CLIENT_SECRET>

# ── Slack ─────────────────────────────────────────────────────
# In api.slack.com/apps → your app → OAuth & Permissions:
#   Add https://<STAGING_REF>.supabase.co/functions/v1/slack-callback
#   as a redirect URL. Can reuse prod app or create a separate staging Slack app.
SLACK_CLIENT_ID=<SLACK_CLIENT_ID>
SLACK_CLIENT_SECRET=<SLACK_CLIENT_SECRET>

# ── Dropbox Sign ─────────────────────────────────────────────
# Use the SANDBOX API key from app.hellosign.com/account/apikeys (Sandbox tab).
# Sandbox mode watermarks documents and signatures are non-binding — safe for testing.
# Sandbox redirect URIs can point to staging.coreflowhr.com.
DROPBOX_SIGN_API_KEY=<DROPBOX_SIGN_SANDBOX_API_KEY>

# ── PDFShift ─────────────────────────────────────────────────
# Same key as prod is fine — PDFShift is not environment-specific.
PDFSHIFT_API_KEY=<PDFSHIFT_API_KEY>

# ── AI / ML ──────────────────────────────────────────────────
GEMINI_API_KEY=<GEMINI_API_KEY>
PDL_API_KEY=<PDL_API_KEY>
# Optional — only needed if CV parsing / sourcing is tested on staging.
# Account requires credits at console.anthropic.com/settings/billing.
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>

# ── Email change flow ─────────────────────────────────────────
# Random 32-char hex secret used to sign email-change tokens.
# Generate: openssl rand -hex 16
EMAIL_CHANGE_SECRET=<RANDOM_32_CHAR_HEX>

# ── Sentry (edge functions) ───────────────────────────────────
# Use a staging-specific Sentry DSN, or leave blank to disable error tracking on staging.
SENTRY_DSN=

# ── Environment identifiers ───────────────────────────────────
# Used for Sentry environment tagging and logging. NEVER set to "production" on staging.
ENVIRONMENT=staging

# CORS — allow only the staging frontend to call edge functions directly.
ALLOWED_ORIGINS=https://staging.coreflowhr.com

# ── URLs ──────────────────────────────────────────────────────
FRONTEND_URL=https://staging.coreflowhr.com
SITE_URL=https://staging.coreflowhr.com

# ── Branding (used in email footers) ─────────────────────────
LOGO_URL=https://staging.coreflowhr.com/logo.png
COMPANY_WEBSITE=https://staging.coreflowhr.com
