{
  "manifest_version": 3,
  "name": "CoreflowHR – Auto Sourcer",
  "version": "2.0.0",
  "description": "Automatically surface top candidates from LinkedIn — detect job changes, bulk import from search results, and push straight to your hiring pipeline.",
  "permissions": ["storage", "activeTab", "alarms"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*",
        "https://www.linkedin.com/search/results/people/*"
      ],
      "js": ["content/content.js"],
      "css": ["styles/content.css"]
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://www.linkedin.com/*"]
    }
  ]
}
