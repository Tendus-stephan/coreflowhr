# ============================================================
# PRODUCTION ENVIRONMENT — set these in Vercel production project
# Dashboard → Project → Settings → Environment Variables
# Environment: Production
# ============================================================
# These values come from the production Supabase project and
# Stripe live mode. Never use test keys here.

# ── Supabase (production project) ───────────────────────────
VITE_SUPABASE_URL=https://lpjyxpxkagctaibmqcoi.supabase.co
VITE_SUPABASE_ANON_KEY=<PROD_ANON_KEY>

# ── Stripe (live keys only) ───────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_<PROD_STRIPE_LIVE_KEY>
VITE_STRIPE_PRICE_ID_PROFESSIONAL_MONTHLY=price_<PROD_LIVE_PRICE_ID>
VITE_STRIPE_PRICE_ID_FOUNDING_MONTHLY=price_<PROD_LIVE_PRICE_ID>

# ── Frontend URL ─────────────────────────────────────────────
VITE_FRONTEND_URL=https://www.coreflowhr.com

# ── Sentry ───────────────────────────────────────────────────
VITE_SENTRY_DSN=https://6d708db0682b7ec5a6b62b14fc7857a0@o4510675090997248.ingest.us.sentry.io/4510741814640640

# ── Calendly ─────────────────────────────────────────────────
VITE_CALENDLY_URL=https://calendly.com/coreflowhr/product-demo

# ============================================================
# Edge Function secrets — set these with the Supabase CLI:
#
#   npx supabase secrets set KEY=value --project-ref lpjyxpxkagctaibmqcoi
#
# Or bulk-set from a file:
#   npx supabase secrets set --env-file .env.production.secrets --project-ref lpjyxpxkagctaibmqcoi
# ============================================================

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=<PROD_RESEND_KEY>
FROM_EMAIL=noreply@coreflowhr.com
FROM_NAME=CoreflowHR
REPLY_TO_EMAIL=support@coreflowhr.com
# Leave blank in production — emails go to actual recipients.
RESEND_FORCE_TO=

# Resend webhook secret — from Resend dashboard → Webhooks → production endpoint.
# Webhook URL: https://lpjyxpxkagctaibmqcoi.supabase.co/functions/v1/receive-candidate-email
RESEND_WEBHOOK_SECRET=<PROD_RESEND_WEBHOOK_SECRET>

# ── Stripe ───────────────────────────────────────────────────
# NEVER use sk_test_ in production.
STRIPE_SECRET_KEY=sk_live_<PROD_STRIPE_LIVE_SECRET>
STRIPE_WEBHOOK_SECRET=whsec_<PROD_STRIPE_WEBHOOK_SECRET>

# ── Google OAuth ─────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URIs must include:
#   https://www.coreflowhr.com/auth/callback
#   https://lpjyxpxkagctaibmqcoi.supabase.co/functions/v1/connect-google-callback
GOOGLE_CLIENT_ID=<PROD_GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<PROD_GOOGLE_CLIENT_SECRET>

# ── Microsoft / Teams ─────────────────────────────────────────
# Azure portal → App registrations → your app → Authentication
# Redirect URI: https://lpjyxpxkagctaibmqcoi.supabase.co/functions/v1/connect-teams-callback
MICROSOFT_CLIENT_ID=<PROD_MICROSOFT_CLIENT_ID>
MICROSOFT_CLIENT_SECRET=<PROD_MICROSOFT_CLIENT_SECRET>

# ── Slack ─────────────────────────────────────────────────────
# api.slack.com/apps → your app → OAuth & Permissions
# Redirect URL: https://lpjyxpxkagctaibmqcoi.supabase.co/functions/v1/slack-callback
SLACK_CLIENT_ID=<PROD_SLACK_CLIENT_ID>
SLACK_CLIENT_SECRET=<PROD_SLACK_CLIENT_SECRET>

# ── Dropbox Sign ─────────────────────────────────────────────
# Use the PRODUCTION API key from app.hellosign.com/account/apikeys (Production tab).
# NEVER use sandbox key in production — signatures would be non-binding.
DROPBOX_SIGN_API_KEY=<PROD_DROPBOX_SIGN_PRODUCTION_API_KEY>

# ── PDFShift ─────────────────────────────────────────────────
PDFSHIFT_API_KEY=<PROD_PDFSHIFT_API_KEY>

# ── AI / ML ──────────────────────────────────────────────────
GEMINI_API_KEY=<PROD_GEMINI_API_KEY>
PDL_API_KEY=<PROD_PDL_API_KEY>
ANTHROPIC_API_KEY=<PROD_ANTHROPIC_API_KEY>

# ── Email change flow ─────────────────────────────────────────
# Random 32-char hex secret. Generate: openssl rand -hex 16
# IMPORTANT: once set, do not change — existing tokens will be invalidated.
EMAIL_CHANGE_SECRET=<PROD_EMAIL_CHANGE_SECRET>

# ── Sentry (edge functions) ───────────────────────────────────
SENTRY_DSN=https://6d708db0682b7ec5a6b62b14fc7857a0@o4510675090997248.ingest.us.sentry.io/4510741814640640

# ── Environment identifiers ───────────────────────────────────
ENVIRONMENT=production

# CORS
ALLOWED_ORIGINS=https://www.coreflowhr.com

# ── URLs ──────────────────────────────────────────────────────
FRONTEND_URL=https://www.coreflowhr.com
SITE_URL=https://www.coreflowhr.com

